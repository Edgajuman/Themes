{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CubicLauncher Theme",
  "type": "object",
  "required": ["name", "variables"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Nombre visible del tema en el selector"
    },
    "author": {
      "type": "string",
      "description": "Autor del tema"
    },
    "version": {
      "type": "string",
      "description": "Versión del tema"
    },
    "type": {
      "type": "string",
      "enum": ["builtin", "user"],
      "description": "Tipo de tema. Siempre 'user' para temas externos; 'builtin' viene incluido en el launcher"
    },
    "fonts": {
      "type": "array",
      "description": "Fuentes personalizadas que el tema puede cargar",
      "items": {
        "$ref": "#/definitions/FontFace"
      }
    },
    "bg_image": {
      "type": "string",
      "description": "Nombre del archivo de imagen de fondo en la misma carpeta (ej: bg.jpg, bg.gif). Máximo 25 MB. Formatos válidos: PNG, JPG, GIF, WEBP."
    },
    "bg_image_blur": {
      "type": "string",
      "description": "Desenfoque del fondo (ej: 8px). El launcher lo aplica como --bg-image-blur en el root."
    },
    "bg_image_opacity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Opacidad del fondo, valor entre 0 y 1. El launcher lo aplica como --bg-image-opacity en el root."
    },
    "bg_image_warning_key": {
      "type": "string",
      "description": "Clave de advertencia interna para problemas con la imagen de fondo (uso interno del launcher)"
    },
    "variables": {
      "type": "object",
      "description": "Variables CSS que definen la apariencia del launcher",
      "minProperties": 1,
      "properties": {
        "--bg-main": {
          "type": "string",
          "description": "Fondo principal de la ventana"
        },
        "--bg-sidebar": {
          "type": "string",
          "description": "Fondo de la barra lateral"
        },
        "--bg-card": {
          "type": "string",
          "description": "Fondo de tarjetas/paneles"
        },
        "--bg-item-active": {
          "type": "string",
          "description": "Fondo del elemento activo en listas"
        },
        "--bg-overlay": {
          "type": "string",
          "description": "Fondo de overlays y modales (acepta rgba)"
        },
        "--bg-input": {
          "type": "string",
          "description": "Fondo de inputs"
        },
        "--bg-sidebar-gradient": {
          "type": "string",
          "description": "Gradiente de fondo de la barra lateral"
        },
        "--bg-card-gradient": {
          "type": "string",
          "description": "Gradiente de fondo de tarjetas"
        },
        "--text-primary": {
          "type": "string",
          "description": "Color de texto principal"
        },
        "--text-secondary": {
          "type": "string",
          "description": "Color de texto secundario"
        },
        "--text-muted": {
          "type": "string",
          "description": "Color de texto desactivado o sutil"
        },
        "--border": {
          "type": "string",
          "description": "Color de bordes (alias de --border-color)"
        },
        "--border-color": {
          "type": "string",
          "description": "Color de bordes"
        },
        "--border-width": {
          "type": "string",
          "description": "Ancho de bordes (ej: 1px)"
        },
        "--border-radius": {
          "type": "string",
          "description": "Radio de borde general (ej: 8px)"
        },
        "--border-radius-sm": {
          "type": "string",
          "description": "Radio de borde pequeño (ej: 4px)"
        },
        "--border-radius-lg": {
          "type": "string",
          "description": "Radio de borde grande (ej: 12px)"
        },
        "--accent": {
          "type": "string",
          "description": "Color de acento principal"
        },
        "--accent-rgb": {
          "type": "string",
          "description": "Acento en formato RGB sin paréntesis, para uso con rgba() (ej: 245,168,106)"
        },
        "--accent-hover": {
          "type": "string",
          "description": "Color de acento al hacer hover"
        },
        "--accent-primary": {
          "type": "string",
          "description": "Color de acento primario (puede diferir de --accent)"
        },
        "--accent-text": {
          "type": "string",
          "description": "Color de texto sobre fondo de acento"
        },
        "--shadow-sm": {
          "type": "string",
          "description": "Sombra pequeña (box-shadow)"
        },
        "--shadow-md": {
          "type": "string",
          "description": "Sombra mediana (box-shadow)"
        },
        "--glow-accent": {
          "type": "string",
          "description": "Brillo del color de acento (box-shadow)"
        },
        "--glow-error": {
          "type": "string",
          "description": "Brillo del color de error (box-shadow)"
        },
        "--glow-success": {
          "type": "string",
          "description": "Brillo del color de éxito (box-shadow)"
        },
        "--color-success": {
          "type": "string",
          "description": "Color de éxito"
        },
        "--color-success-rgb": {
          "type": "string",
          "description": "Color de éxito en formato RGB sin paréntesis (ej: 95,184,106)"
        },
        "--color-error": {
          "type": "string",
          "description": "Color de error"
        },
        "--color-error-rgb": {
          "type": "string",
          "description": "Color de error en formato RGB sin paréntesis (ej: 232,90,90)"
        },
        "--color-warning": {
          "type": "string",
          "description": "Color de advertencia"
        },
        "--color-warning-rgb": {
          "type": "string",
          "description": "Color de advertencia en formato RGB sin paréntesis (ej: 232,168,64)"
        },
        "--color-status-starting": {
          "type": "string",
          "description": "Color del estado 'iniciando' de un servidor"
        },
        "--color-status-started": {
          "type": "string",
          "description": "Color del estado 'iniciado' de un servidor"
        },
        "--clr-loader-vanilla": {
          "type": "string",
          "description": "Color del loader para Vanilla"
        },
        "--clr-loader-fabric": {
          "type": "string",
          "description": "Color del loader para Fabric"
        },
        "--clr-loader-forge": {
          "type": "string",
          "description": "Color del loader para Forge"
        },
        "--clr-loader-quilt": {
          "type": "string",
          "description": "Color del loader para Quilt"
        },
        "--icon-filter": {
          "type": "string",
          "description": "Filtro CSS para iconos normales (ej: invert(90%) sepia(10%))"
        },
        "--icon-filter-error": {
          "type": "string",
          "description": "Filtro CSS para iconos de error"
        },
        "--sidebar-width": {
          "type": "string",
          "description": "Ancho de la barra lateral (ej: 260px)"
        },
        "--scrollbar-track": {
          "type": "string",
          "description": "Fondo del track del scrollbar"
        },
        "--scrollbar-thumb": {
          "type": "string",
          "description": "Color del thumb del scrollbar"
        },
        "--font-family": {
          "type": "string",
          "description": "Familia de fuente principal (ej: Cantarell, sans-serif)"
        },
        "--font-size-base": {
          "type": "string",
          "description": "Tamaño de fuente base (ej: 14px)"
        },
        "--font-size-sm": {
          "type": "string",
          "description": "Tamaño de fuente pequeño (ej: 12px)"
        },
        "--font-size-lg": {
          "type": "string",
          "description": "Tamaño de fuente grande (ej: 16px)"
        }
      },
      "additionalProperties": {
        "type": "string",
        "description": "Variable CSS adicional"
      }
    }
  },
  "definitions": {
    "FontFace": {
      "type": "object",
      "required": ["family", "src"],
      "properties": {
        "family": {
          "type": "string",
          "description": "Nombre de la familia tipográfica"
        },
        "src": {
          "type": "string",
          "description": "Ruta al archivo de fuente dentro de la carpeta del tema (ej: font.woff2)"
        },
        "format": {
          "type": "string",
          "description": "Formato de la fuente (ej: woff2, ttf, otf)"
        },
        "weight": {
          "type": "string",
          "description": "Peso de la fuente (ej: 400, bold)"
        },
        "style": {
          "type": "string",
          "description": "Estilo de la fuente (ej: normal, italic)"
        }
      },
      "additionalProperties": false
    }
  }
}
